<UserControl x:Class="Flarial.Pages.options.AboutOptions"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Flarial.Pages.options"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="375">
    <Grid>
        <StackPanel Orientation="Vertical"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Image Source="/Assets/Images/logo.png" 
                   Width="100" 
                   Height="70"/>
            <TextBlock FontSize="12" 
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
                <Run Style="{DynamicResource MainGreeting}"
                     Text="Flarial Reskin"
                     FontWeight="DemiBold"/>
                <LineBreak/>
                <Run Style="{DynamicResource SecondaryGreeting}"
                     Text="V1.0.0"
                     x:Name="Versiontxt"/>
            </TextBlock>

        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Bottom"
                    FlowDirection="RightToLeft"
                    Margin="8">
            <Image Source="/Assets/Images/Social/github.png" 
                       Width="30" 
                       Height="30"
                       Margin="0,0,5,0"
                       Style="{DynamicResource LinkImage}"
                       IsHitTestVisible="True"
                       MouseDown="Social_MouseDown">
            </Image>
            </StackPanel>

        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Foreground="#80FFFFFF"
                   FontSize="10"
                   Opacity="0.7"
                   Margin="9"
                   FontFamily="Comic Sans MS">
            <Run Text="Made with ❤️ by "/>
            <Hyperlink NavigateUri="https://github.com/yousif51811"
                       RequestNavigate="Hyperlink_RequestNavigate">
                       yousif51811</Hyperlink>
        </TextBlock>
    </Grid>
</UserControl>
